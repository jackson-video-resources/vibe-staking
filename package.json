{
  "name": "vibe-staking",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external --external:pg-native",
    "start": "node dist/server.js",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@lifi/sdk": "^3.4.1",
    "@polkadot/api": "^14.2.3",
    "@polkadot/keyring": "^13.2.3",
    "@polkadot/util-crypto": "^13.2.3",
    "@solana/web3.js": "^1.98.0",
    "@tanstack/react-query": "^5.66.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.40.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.4.7",
    "helmet": "^8.0.0",
    "lucide-react": "^0.475.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-3d": "^1.24.6",
    "telegraf": "^4.16.3",
    "three": "^0.172.0",
    "viem": "^2.23.0",
    "wouter": "^3.6.0"
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.24.2",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.6"
  }
}
