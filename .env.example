# PostgreSQL - auto-populated by Railway addon
DATABASE_URL=postgresql://user:password@host:5432/vibe_staking

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Admin key — required to save settings from the dashboard. Generate: openssl rand -hex 16
# Set the same value in Railway AND in your local .env as VITE_ADMIN_KEY for the frontend build
ADMIN_KEY=
VITE_ADMIN_KEY=

# Anthropic - for Claude portfolio decisions
ANTHROPIC_API_KEY=

# Telegram - get from @BotFather and @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk tolerance 1-10 (1=very conservative, 10=degen)
RISK_TOLERANCE=5

# Set by Railway automatically
PORT=3000
NODE_ENV=production
